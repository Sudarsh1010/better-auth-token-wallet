{
  "name": "better-auth-token-wallet",
  "version": "0.0.0",
  "description": "Token Wallet plugin for Better Auth.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./types": {
      "dev-source": "./src/types.ts",
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ],
      "types": [
        "./dist/types.d.mts"
      ]
    }
  },
  "peerDependencies": {
    "better-auth": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite-plus": "^0.1.14"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch"
  }
}
